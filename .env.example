# ============================================================
# BuffettEye — Variables de Entorno (copiar a .env y completar)
# ============================================================

# Token del bot de Telegram (obtenido con @BotFather)
TELEGRAM_TOKEN=your_bot_token_here

# Chat ID del destinatario (obtenido con @userinfobot o /getUpdates)
TELEGRAM_CHAT_ID=your_chat_id_here

# Intervalo de escaneo en minutos (default: 15)
SCAN_INTERVAL_MINUTES=15

# Umbral mínimo de descuento CCL para alertar (en %, default: 2.0)
CCL_DISCOUNT_THRESHOLD=2.0
